{
  "crons": [
    {
      "path": "/api/send-digest",
      "schedule": "0 22 * * 4"
    },
    {
      "path": "/api/send-upgrade-nudge",
      "schedule": "0 10 * * *"
    }
  ],
  "rewrites": [
    { "source": "/wtdgadmin",              "destination": "/wtdgadmin.html" },
    { "source": "/wtdgadmin/dash",         "destination": "/wtdgadmin-dash.html" },
    { "source": "/wtdgadmin/users",        "destination": "/wtdgadmin-users.html" },
    { "source": "/wtdgadmin/businesses",   "destination": "/wtdgadmin-businesses.html" },
    { "source": "/wtdgadmin/events",       "destination": "/wtdgadmin-events.html" },
    { "source": "/wtdgadmin/offers",       "destination": "/wtdgadmin-offers.html" },
    { "source": "/wtdgadmin/revenue",      "destination": "/wtdgadmin-revenue.html" },
    { "source": "/wtdgadmin/settings",     "destination": "/wtdgadmin-settings.html" },
    { "source": "/wtdgadmin/inquiries",    "destination": "/wtdgadmin-inquiries.html" },
    { "source": "/wtdgadmin/homepage",    "destination": "/wtdgadmin-homepage.html" },
    { "source": "/wtdgadmin/content",      "destination": "/wtdgadmin-content.html" },
    { "source": "/wtdgadmin/promotions",   "destination": "/wtdgadmin-promotions.html" },
    { "source": "/do",                      "destination": "/do.html" },
    { "source": "/drink",                   "destination": "/drink.html" },
    { "source": "/advertise",              "destination": "/advertise.html" },
    { "source": "/maintenance",            "destination": "/maintenance.html" },
    { "source": "/coming-soon",            "destination": "/comingsoon.html" },
    { "source": "/news/:slug",   "destination": "/article.html?s=:slug" },
    { "source": "/events/:slug", "destination": "/event.html?s=:slug" },
    { "source": "/guide/:id",              "destination": "/guide.html?id=:id" },
    { "source": "/community-guides",       "destination": "/community-guides.html" },
    { "source": "/promote-event",          "destination": "/promote-event.html" },
    { "source": "/upgrade",                "destination": "/upgrade.html" },
    { "source": "/:biz/:item",   "destination": "/event.html?b=:biz&s=:item" },
    { "source": "/:slug",        "destination": "/listing.html?s=:slug" }
  ]
}
